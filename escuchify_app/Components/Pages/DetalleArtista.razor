@page "/artista/{Id:int}"
@rendermode InteractiveServer
@inject escuchify_app.Services.ApiService Api
@inject IJSRuntime JS
@using escuchify_app.Components.UI
@using escuchify_app.Models

<div class="p-8 text-white min-h-screen pb-20">
    <a href="/artistas" class="mb-6 inline-flex items-center gap-2 text-slate-400 hover:text-white transition">
        <span>⬅</span> Volver a la lista
    </a>

    @if (artista == null)
    {
        <p class="text-center mt-20 animate-pulse text-cyan-500 font-bold">Cargando artista...</p>
    }
    else
    {
        <div class="flex flex-col md:flex-row gap-8 items-center mb-12 bg-white/5 p-6 rounded-3xl border border-white/5">
            
            <div class="w-64 h-64 rounded-full overflow-hidden shadow-2xl border-4 border-cyan-500/30 shrink-0">
                <ImagenAutomatica Termino="@artista.Nombre" Tipo="artista" />
            </div>
            
            <div class="text-center md:text-left flex-1 w-full">
                @if (editandoArtista)
                {
                    <div class="flex flex-col gap-3 p-4 bg-slate-800/80 rounded-xl border border-cyan-500 shadow-xl max-w-md animate-in fade-in zoom-in duration-200">
                        <label class="text-xs text-cyan-400 font-bold uppercase">Nombre</label>
                        <input @bind="artista.Nombre" class="bg-slate-900 text-white text-2xl font-bold p-2 rounded border border-slate-600 focus:border-cyan-500 outline-none" />
                        
                        <label class="text-xs text-cyan-400 font-bold uppercase">Género</label>
                        <input @bind="artista.Genero" class="bg-slate-900 text-white p-2 rounded border border-slate-600 focus:border-cyan-500 outline-none" />
                        
                        <div class="flex gap-2 mt-2 justify-end">
                            <button @onclick="CancelarEdicionArtista" class="px-4 py-2 rounded text-sm font-bold text-slate-300 hover:bg-slate-700 transition">Cancelar</button>
                            <button @onclick="GuardarArtista" class="bg-green-600 px-6 py-2 rounded text-sm font-bold hover:bg-green-500 shadow-lg transition">Guardar</button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="group relative inline-block">
                        <h1 class="text-6xl font-black mb-2 text-transparent bg-clip-text bg-gradient-to-r from-white to-slate-400">@artista.Nombre</h1>
                        <button @onclick="() => editandoArtista = true" class="absolute -right-10 top-2 opacity-0 group-hover:opacity-100 text-slate-500 hover:text-cyan-400 transition p-2" title="Editar Artista">
                            ✏️
                        </button>
                    </div>
                    <div class="mt-2">
                        <span class="bg-slate-800 text-cyan-400 px-4 py-1 rounded-full text-sm font-bold uppercase tracking-wider border border-white/10 shadow-sm">
                            @artista.Genero
                        </span>
                    </div>
                }
            </div>
        </div>

        <div class="flex flex-wrap justify-between items-end mb-6 border-b border-white/10 pb-4 gap-4">
            <h2 class="text-3xl font-bold flex items-center gap-2">
                💿 Discografía 
                <span class="text-sm font-normal text-slate-500 mt-1">(@(artista.Discos?.Count ?? 0))</span>
            </h2>
            
            <EditForm Model="nuevoDisco" OnValidSubmit="AgregarDisco" class="flex gap-2 bg-slate-800 p-2 rounded-xl border border-white/10 shadow-lg items-start">
                <DataAnnotationsValidator />
                
                <div class="flex flex-col">
                    <InputText @bind-Value="nuevoDisco.Titulo" placeholder="Nuevo Álbum" class="bg-slate-900 text-white px-3 py-1.5 rounded-lg outline-none placeholder-slate-500 w-40 border border-transparent focus:border-cyan-500 transition text-sm" />
                </div>

                <div class="flex flex-col">
                    <InputNumber @bind-Value="nuevoDisco.AnioLanzamiento" placeholder="Año" class="bg-slate-900 text-white px-3 py-1.5 rounded-lg outline-none border border-transparent focus:border-cyan-500 placeholder-slate-500 w-20 text-center text-sm" />
                </div>

                <button type="submit" class="bg-purple-600 hover:bg-purple-500 px-4 py-1.5 rounded-lg text-sm font-bold transition h-full shadow-md hover:shadow-purple-500/20">
                    +
                </button>
            </EditForm>
        </div>

        @if (artista.Discos == null || artista.Discos.Count == 0)
        {
            <div class="p-16 bg-slate-800/30 rounded-3xl text-center border-2 border-dashed border-slate-700">
                <p class="text-2xl text-slate-500 font-bold mb-2">Este artista está vacío 👻</p>
                <p class="text-slate-600">Agrega su primer álbum usando el formulario de arriba.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
                @foreach (var disco in artista.Discos)
                {
                    @if (discoEditandoId == disco.Id)
                    {
                        <div @key="disco.Id" class="bg-slate-800 p-4 rounded-2xl border-2 border-cyan-500 shadow-2xl flex flex-col gap-3 relative z-30 animate-in fade-in duration-200">
                            <label class="text-[10px] text-cyan-400 font-bold uppercase tracking-wider">Título</label>
                            <input @bind="disco.Titulo" class="bg-slate-900 text-white p-2 rounded-lg border border-slate-600 text-sm w-full outline-none focus:border-cyan-500" />
                            
                            <label class="text-[10px] text-cyan-400 font-bold uppercase tracking-wider">Año</label>
                            <input @bind="disco.AnioLanzamiento" class="bg-slate-900 text-white p-2 rounded-lg border border-slate-600 text-sm w-full outline-none focus:border-cyan-500" />

                            <div class="flex gap-2 mt-2">
                                <button @onclick="() => GuardarDisco(disco)" class="bg-green-600 p-2 rounded-lg hover:bg-green-500 text-xs font-bold flex-1 transition shadow-lg">💾</button>
                                <button @onclick="CancelarEdicionDisco" class="bg-gray-600 p-2 rounded-lg hover:bg-gray-500 text-xs font-bold flex-1 transition">❌</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div @key="disco.Id" class="relative group">
                            
                            <div class="absolute top-2 right-2 z-20 flex gap-2 opacity-0 group-hover:opacity-100 transition-all duration-300 transform group-hover:translate-y-0 translate-y-2">
                                <button @onclick="() => IniciarEdicionDisco(disco.Id)" @onclick:stopPropagation="true" class="bg-slate-900/90 hover:bg-cyan-500 text-white p-2 rounded-full shadow-lg backdrop-blur-md transition hover:scale-110 border border-white/10" title="Editar">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                                </button>
                                <button @onclick="() => EliminarDisco(disco)" @onclick:stopPropagation="true" class="bg-slate-900/90 hover:bg-red-500 text-white p-2 rounded-full shadow-lg backdrop-blur-md transition hover:scale-110 border border-white/10" title="Eliminar">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                                </button>
                            </div>

                            <a href="/disco/@disco.Id" class="block cursor-pointer">
                                <div class="aspect-square rounded-2xl overflow-hidden mb-3 shadow-lg border border-white/5 group-hover:border-cyan-500/50 transition-all duration-300 group-hover:-translate-y-1">
                                    <ImagenAutomatica Termino="@($"{artista.Nombre} {disco.Titulo}")" Tipo="album" />
                                </div>
                                <h4 class="font-bold truncate text-slate-200 group-hover:text-cyan-400 transition">@disco.Titulo</h4>
                                <p class="text-xs text-slate-500 font-mono bg-slate-800 inline-block px-2 py-0.5 rounded mt-1">@disco.AnioLanzamiento</p>
                            </a>
                        </div>
                    }
                }
            </div>
        }
    }
</div>
@code {
    [Parameter] public int Id { get; set; }
    
    // Modelos
    escuchify_app.Models.Artista? artista;
    escuchify_app.Models.Disco nuevoDisco = new();

    // --- ESTADO DE EDICIÓN  ---
    bool editandoArtista = false;
    int? discoEditandoId = null;

    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

    async Task Cargar()
    {
        artista = await Api.ObtenerArtistaPorId(Id);
    }

    // --- MÉTODOS ARTISTA  ---
    void CancelarEdicionArtista() => editandoArtista = false;

    async Task GuardarArtista()
    {
        if (artista != null)
        {
            await Api.ActualizarArtista(artista.Id, artista);
            editandoArtista = false;
        }
    }

    // --- MÉTODOS DISCO ---
    void IniciarEdicionDisco(int id) => discoEditandoId = id;
    void CancelarEdicionDisco() => discoEditandoId = null;

    async Task GuardarDisco(escuchify_app.Models.Disco disco)
    {
        await Api.ActualizarDisco(disco.Id, disco);
        discoEditandoId = null;
    }
    async Task AgregarDisco()
    {
        if (artista == null) return;
        
        // 1. Asignamos datos automáticos
        nuevoDisco.Genero = artista.Genero;
        if (nuevoDisco.AnioLanzamiento == 0) nuevoDisco.AnioLanzamiento = DateTime.Now.Year;

        // 2. Enviamos a la API
        await Api.CrearDisco(Id, nuevoDisco);

        // 3. ¡ESTO ES LO QUE FALTABA! (La Alerta Jelly)
        await JS.InvokeVoidAsync("Swal.fire", new {
            icon = "success",
            title = "¡Disco Agregado!",
            text = $"Se añadió '{nuevoDisco.Titulo}' a la discografía.",
            background = "#1e293b", // Fondo oscuro
            color = "#fff",          // Texto blanco
            timer = 2000,            // Se va solo a los 2 segundos
            showConfirmButton = false
        });

        // 4. Limpiamos y recargamos
        nuevoDisco = new escuchify_app.Models.Disco(); 
        await Cargar();
    }
    async Task EliminarDisco(escuchify_app.Models.Disco disco)
    {
        // 1. Alerta de Confirmación Bonita (Estilo Cyberpunk)
        var resultado = await JS.InvokeAsync<SweetAlertResult>("Swal.fire", new 
        {
            title = "¿Estás seguro?",
            text = $"Vas a eliminar el álbum '{disco.Titulo}' y sus canciones.",
            icon = "warning",
            showCancelButton = true,
            confirmButtonColor = "#d33",
            cancelButtonColor = "#3085d6",
            confirmButtonText = "Sí, borrar",
            cancelButtonText = "Cancelar",
            background = "#1e293b", // Color oscuro
            color = "#fff" // Texto blanco
        });

        if (resultado.isConfirmed)
        {
            await Api.BorrarDisco(disco.Id);
            await Cargar();
            
            // 2. Alerta de Éxito Fugaz
            await JS.InvokeVoidAsync("Swal.fire", new {
                title = "¡Eliminado!",
                text = "El disco ha sido borrado.",
                icon = "success",
                timer = 1500,
                showConfirmButton = false,
                background = "#1e293b",
                color = "#fff"
            });
        }
    }
    public class SweetAlertResult { public bool isConfirmed { get; set; } }
}