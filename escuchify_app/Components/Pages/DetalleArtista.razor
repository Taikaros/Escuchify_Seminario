@page "/artista/{Id:int}"
@rendermode InteractiveServer
@inject escuchify_app.Services.ApiService Api
@inject IJSRuntime JS
@using System.Threading.Tasks
@using escuchify_app.Components.UI

<div class="p-8 text-white min-h-screen">
    <a href="/artistas" class="mb-6 inline-block text-slate-400 hover:text-white transition">
        ⬅ Volver a la lista
    </a>
    @if (artista == null)
    {
        <p class="text-center mt-20 animate-pulse text-cyan-500">Cargando...</p>
    }
    else
    {
        <div class="flex flex-col md:flex-row gap-8 items-center mb-12">

            <div class="w-64 h-64 rounded-full overflow-hidden shadow-2xl border-4 border-cyan-500/30">
                <ImagenAutomatica Termino="@artista.Nombre" Tipo="artista" />
            </div>

            <div class="text-center md:text-left flex-1">
                @if (editando)
                {
                    <div class="flex flex-col gap-3 p-4 bg-slate-800 rounded-xl border border-cyan-500/50 shadow-xl max-w-md">
                        <label class="text-xs text-cyan-400 font-bold uppercase">Editar Nombre</label>
                        <input @bind="artista.Nombre"
                            class="bg-slate-900 text-white text-2xl font-bold p-2 rounded border border-slate-600 focus:border-cyan-500 outline-none" />

                        <label class="text-xs text-cyan-400 font-bold uppercase">Editar Género</label>
                        <input @bind="artista.Genero"
                            class="bg-slate-900 text-white p-2 rounded border border-slate-600 focus:border-cyan-500 outline-none" />

                        <div class="flex gap-2 mt-2 justify-end">
                            <button @onclick="CancelarEdicion"
                                class="px-4 py-2 rounded text-sm font-bold text-slate-300 hover:text-white hover:bg-slate-700 transition">Cancelar</button>
                            <button @onclick="GuardarCambios"
                                class="bg-green-600 px-6 py-2 rounded text-sm font-bold hover:bg-green-500 shadow-lg transition">Guardar</button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="flex items-center gap-4 justify-center md:justify-start group">
                        <h1 class="text-6xl font-black mb-2">@artista.Nombre</h1>

                        <button @onclick="() => editando = true"
                            class="bg-slate-800 hover:bg-slate-700 text-cyan-400 p-2 rounded-full border border-white/10 transition shadow-sm"
                            title="Editar datos">
                            ✏️
                        </button>
                    </div>

                    <span
                        class="bg-slate-800 text-cyan-400 px-4 py-1 rounded-full text-sm font-bold uppercase tracking-wider border border-white/10 mt-2 inline-block">
                        @artista.Genero
                    </span>
                }
            </div>
        </div>
        <div class="flex justify-between items-end mb-6 border-b border-white/10 pb-4">
            <h2 class="text-3xl font-bold">Discografía</h2>

            <div class="flex gap-2 bg-white/5 p-1 rounded-lg border border-white/10">
                <input @bind="tituloDisco" placeholder="Álbum (ej: Nevermind)"
                    class="bg-transparent text-white px-3 py-1 outline-none placeholder-slate-500 w-40" />
                <input @bind="anioDisco" placeholder="Año"
                    class="bg-transparent text-white px-3 py-1 outline-none border-l border-white/10 placeholder-slate-500 w-20" />
                <button @onclick="AgregarDisco"
                    class="bg-purple-600 hover:bg-purple-500 px-4 py-1 rounded text-sm font-bold transition">
                    +
                </button>
            </div>
        </div>

        @if (artista.Discos == null || artista.Discos.Count == 0)
        {
            <div class="p-10 bg-white/5 rounded-xl text-center border-2 border-dashed border-white/10">
                <p class="text-slate-400">Este artista aún no tiene discos.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-6">
                @foreach (var disco in artista.Discos)
                {
                    @if (discoEditandoId == disco.Id)
                    {
                        <div class="bg-slate-800 p-3 rounded-lg border border-cyan-500 shadow-xl flex flex-col gap-2 relative z-30">
                            <label class="text-[10px] text-cyan-400 font-bold uppercase">Título</label>
                            <input @bind="disco.Titulo"
                                class="bg-slate-900 text-white p-1 rounded border border-slate-600 text-sm w-full" />

                            <label class="text-[10px] text-cyan-400 font-bold uppercase">Año</label>
                            <input @bind="disco.AnioLanzamiento"
                                class="bg-slate-900 text-white p-1 rounded border border-slate-600 text-sm w-full" />

                            <div class="flex gap-2 mt-2">
                                <button @onclick="() => GuardarDisco(disco)"
                                    class="bg-green-600 p-1 rounded hover:bg-green-500 text-xs font-bold flex-1">💾</button>
                                <button @onclick="CancelarEdicionDisco"
                                    class="bg-gray-600 p-1 rounded hover:bg-gray-500 text-xs font-bold flex-1">❌</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div @key="disco.Id" class="relative group">

                            <div
                                class="absolute top-2 right-2 z-20 flex gap-1 opacity-0 group-hover:opacity-100 transition-all duration-200">
                                <button @onclick="() => IniciarEdicionDisco(disco.Id)" @onclick:stopPropagation="true"
                                    class="bg-slate-700/80 hover:bg-cyan-600 text-white p-1.5 rounded-full shadow-lg backdrop-blur-md">
                                    ✏️
                                </button>
                                <button @onclick="() => EliminarDisco(disco)" @onclick:stopPropagation="true"
                                    class="bg-slate-700/80 hover:bg-red-600 text-white p-1.5 rounded-full shadow-lg backdrop-blur-md">
                                    🗑️
                                </button>
                            </div>

                            <a href="/disco/@disco.Id" class="block cursor-pointer">
                                <div
                                    class="aspect-square rounded-lg overflow-hidden mb-3 shadow-lg border border-white/5 group-hover:border-cyan-500/50 transition">
                                    <ImagenAutomatica Termino="@($"{artista.Nombre} {disco.Titulo}")" Tipo="album" />
                                </div>
                                <h4 class="font-bold truncate text-slate-200 group-hover:text-cyan-400 transition">@disco.Titulo</h4>
                                <p class="text-xs text-slate-500">@disco.AnioLanzamiento</p>
                            </a>
                        </div>
                    }
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    escuchify_app.Models.Artista? artista;

    // Variables del formulario
    string tituloDisco = "";
    string anioDisco = "";
    bool editando = false;
    int? discoEditandoId = null;
    void EditarDisco(int id) => discoEditandoId = id;
    void CancelarEdicionDisco() => discoEditandoId = null;

    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

    async Task Cargar()
    {
        artista = await Api.ObtenerArtistaPorId(Id);
    }

    async Task AgregarDisco()
    {
        if (string.IsNullOrWhiteSpace(tituloDisco)) return;

        // Creamos el objeto Disco
        var nuevoDisco = new escuchify_app.Models.Disco
        {
            Titulo = tituloDisco,
            // Truco: Si falla el parseo pone 2024 por defecto para que no explote
            AnioLanzamiento = int.TryParse(anioDisco, out int a) ? a : 2024,
            Genero = artista.Genero
        };

        // Lo enviamos a la API
        await Api.CrearDisco(Id, nuevoDisco);

        // Limpiamos y recargamos
        tituloDisco = "";
        anioDisco = "";
        await Cargar();
    }
    async Task EliminarDisco(escuchify_app.Models.Disco disco)
    {
        bool confirmado = await JS.InvokeAsync<bool>("confirm", $"¿Eliminar el álbum '{disco.Titulo}' y todas sus canciones?");

        if (confirmado)
        {
            await Api.BorrarDisco(disco.Id); // Asegúrate de tener este método en ApiService
            await Cargar(); // Recargamos para que desaparezca visualmente
        }
    }
    async Task CancelarEdicion()
    {
        editando = false;
        await Cargar();
    }
    async Task GuardarCambios()
    {
        if (artista != null)
        {
            await Api.ActualizarArtista(artista.Id, artista);
            editando = false;
        }
    }

    void IniciarEdicionDisco(int id)
    {
        discoEditandoId = id;
    }

    async Task GuardarDisco(escuchify_app.Models.Disco disco)
    {
        await Api.ActualizarDisco(disco.Id, disco);
        discoEditandoId = null; // Salir modo edición
    }
}