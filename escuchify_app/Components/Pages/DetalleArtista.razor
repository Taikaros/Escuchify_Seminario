@page "/artista/{Id:int}"
@rendermode InteractiveServer
@inject escuchify_app.Services.ApiService Api
@using escuchify_app.Components.UI

<div class="p-8 text-white min-h-screen">
    @if (artista == null)
    {
        <p class="text-center mt-20 animate-pulse text-cyan-500">Cargando...</p>
    }
    else
    {
        <div class="flex flex-col md:flex-row gap-8 items-center mb-12">
            <div class="w-64 h-64 rounded-full overflow-hidden shadow-2xl border-4 border-cyan-500/30">
                <ImagenAutomatica Termino="@artista.Nombre" Tipo="artista" />
            </div>
            
            <div class="text-center md:text-left">
                <h1 class="text-6xl font-black mb-2">@artista.Nombre</h1>
                <span class="bg-slate-800 text-cyan-400 px-4 py-1 rounded-full text-sm font-bold uppercase tracking-wider border border-white/10">
                    @artista.Genero
                </span>
            </div>
        </div>

        <div class="flex justify-between items-end mb-6 border-b border-white/10 pb-4">
            <h2 class="text-3xl font-bold">Discografía</h2>
            
            <div class="flex gap-2 bg-white/5 p-1 rounded-lg border border-white/10">
                <input @bind="tituloDisco" placeholder="Álbum (ej: Nevermind)" class="bg-transparent text-white px-3 py-1 outline-none placeholder-slate-500 w-40" />
                <input @bind="anioDisco" placeholder="Año" class="bg-transparent text-white px-3 py-1 outline-none border-l border-white/10 placeholder-slate-500 w-20" />
                <button @onclick="AgregarDisco" class="bg-purple-600 hover:bg-purple-500 px-4 py-1 rounded text-sm font-bold transition">
                    +
                </button>
            </div>
        </div>

        @if (artista.Discos == null || artista.Discos.Count == 0)
        {
            <div class="p-10 bg-white/5 rounded-xl text-center border-2 border-dashed border-white/10">
                <p class="text-slate-400">Este artista aún no tiene discos.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-6">
                @foreach (var disco in artista.Discos)
                {
                    <div class="group cursor-pointer">
                        <div class="aspect-square rounded-lg overflow-hidden mb-3 shadow-lg border border-white/5 group-hover:border-cyan-500/50 transition">
                            <ImagenAutomatica Termino="@($"{artista.Nombre} {disco.Titulo}")" Tipo="album" />
                        </div>
                        <h4 class="font-bold truncate text-slate-200 group-hover:text-cyan-400 transition">@disco.Titulo</h4>
                        <p class="text-xs text-slate-500">@disco.AnioLanzamiento</p>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    escuchify_app.Models.Artista? artista;
    
    // Variables del formulario
    string tituloDisco = "";
    string anioDisco = "";

    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

    async Task Cargar()
    {
        artista = await Api.ObtenerArtistaPorId(Id);
    }

    async Task AgregarDisco()
    {
        if (string.IsNullOrWhiteSpace(tituloDisco)) return;

        // Creamos el objeto Disco
        var nuevoDisco = new escuchify_app.Models.Disco 
        { 
            Titulo = tituloDisco, 
            // Truco: Si falla el parseo pone 2024 por defecto para que no explote
            AnioLanzamiento = int.TryParse(anioDisco, out int a) ? a : 2024, 
            Genero = artista.Genero 
        };

        // Lo enviamos a la API
        await Api.CrearDisco(Id, nuevoDisco);

        // Limpiamos y recargamos
        tituloDisco = "";
        anioDisco = "";
        await Cargar();
    }
}