@page "/counter"

<div class="min-h-screen bg-slate-900 flex flex-col items-center justify-center space-y-8">
    
    <h1 class="text-6xl font-black text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-purple-600 animate-pulse">
        CONTADOR
    </h1>

    <div class="bg-slate-800 p-10 rounded-2xl shadow-2xl border border-slate-700 text-center transform hover:scale-105 transition duration-300">
        <p class="text-slate-400 text-lg mb-2">Cuenta actual:</p>
        <p class="text-5xl font-mono text-white mb-8" role="status">@currentCount</p>

        <button class="bg-gradient-to-r from-blue-500 to-cyan-500 hover:from-blue-600 hover:to-cyan-600 text-white font-bold py-3 px-8 rounded-full shadow-lg transform active:scale-95 transition-all duration-200 ring-4 ring-transparent hover:ring-cyan-500/30" 
                @onclick="IncrementCount">
            🚀 Aumentar Energía
        </button>
    </div>

</div>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
